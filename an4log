THREAT_PATTERNS = {
    'SQL': re.compile(
        r'(union(\s|%20)+select|sleep\(|benchmark\(|information_schema|'
        r'load_file|EXTRACTVALUE\(|INTO\s+OUTFILE|xp_cmdshell|CONCAT\(0x)', re.I),
    'XSS': re.compile(
        r'(<script|%3cscript|javascript:|onerror=|onload=|alert\(|prompt\(|document\.cookie)', re.I),
