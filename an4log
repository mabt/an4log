    if not db_path:
        warn("Base GeoIP introuvable")
        print("    an4log setup-geoip")
        return
    try:
        import geoip2.database
    except ImportError:
        warn("module python geoip2 non trouve")
        print("    pip3 install geoip2")
        return

    reader = geoip2.database.Reader(db_path)
    country_ips = Counter()
    country_hits = Counter()

    for ip, hits in data['ip_counts'].items():
        try:
            r = reader.country(ip)
            key = f"{r.country.iso_code or '??'}|{r.country.name or 'Inconnu'}"
        except Exception:
            key = "??|Inconnu"
        country_ips[key] += 1
        country_hits[key] += hits
    reader.close()

    total_ips = sum(country_ips.values())
    total_hits = sum(country_hits.values())
    print(f"  Total: {total_ips} IPs uniques, {total_hits} hits\n")
    print(f"{'#':>3}  {'Pays':30s} {'Code':>4}  | {'IPs uniques':>12} | {'Hits':>12} | {'% hits':>7}")
    print('-' * 85)
    for i, (key, hits) in enumerate(country_hits.most_common(cfg['top_n']), 1):
        iso, name = key.split('|', 1)
        ips = country_ips[key]
        pct = hits / total_hits * 100 if total_hits else 0
        print(f"{i:3d}  {name:30s} {iso:>4}  | {ips:>12,} | {hits:>12,} | {pct:6.2f}%")


def is_protected_ip(ip, data):
    """IPs tagged PAYMENT or MONITORING should never be suggested for ban."""
    return bool(data['ip_classes'].get(ip, set()) & {'PAYMENT', 'MONITORING'})


def cmd_classify(data, cfg, **_):
    header("Classification du trafic")
    total = data['total']
    if not total:
        print(f"  {C.YELLOW}Aucune requete{C.RESET}")
        return

    # Category order and labels
    cats = [
        ('HUMAN', 'Humain (navigateurs)'),
        ('PAYMENT', 'Paiement (Lyra, PayPal, Stripe...)'),
        ('MONITORING', 'Monitoring (Uptime, Sansec...)'),
        ('LEGIT_BOT', 'Bots legitimes (Google, Bing...)'),
        ('SEO', 'SEO (Semrush, Ahrefs, OnCrawl...)'),
        ('AI_BOT', 'IA (GPTBot, ClaudeBot...)'),
        ('UNKNOWN', 'Sans User-Agent / inconnu'),
    ]
    # Bots detected by BOT_RE but not classified above
    classified = sum(data['ua_class_counts'].values())
    other_bots = data['bot_count'] - sum(
        data['ua_class_counts'].get(c, 0) for c in ('LEGIT_BOT', 'SEO', 'AI_BOT'))
    if other_bots < 0:
        other_bots = 0

    max_val = max(data['ua_class_counts'].values()) if data['ua_class_counts'] else 1
    colors = {'HUMAN': C.GREEN, 'PAYMENT': C.CYAN, 'MONITORING': C.CYAN,
              'LEGIT_BOT': C.GREEN, 'SEO': C.YELLOW, 'AI_BOT': C.YELLOW, 'UNKNOWN': C.RED}
    for key, label in cats:
        count = data['ua_class_counts'].get(key, 0)
        if count == 0 and key == 'UNKNOWN':
            continue
        ips = len(data['ua_class_ips'].get(key, set()))
        pct = count / total * 100
        col = colors.get(key, '')
        bar = fmt_bar(count, max_val, 15)
        ip_str = f"  ({ips} IPs)" if ips else ''
        print(f"  {col}{label:40s}{C.RESET}  {count:>8,}  {pct:5.1f}%  {bar}{ip_str}")
    if other_bots > 0:
        pct = other_bots / total * 100
        print(f"  {'Autres bots/crawlers':40s}  {other_bots:>8,}  {pct:5.1f}%")

    # Payment URIs
    if data['payment_uri_hits']:
        header("Activite paiement (URIs checkout/payment/webhook)")
        for ip, hits in data['payment_uri_hits'].most_common(cfg['top_n']):
            classes = ','.join(sorted(data['ip_classes'].get(ip, set()))) or 'HUMAN'
            protected = f"  {C.GREEN}[PROTEGE]{C.RESET}" if is_protected_ip(ip, data) else ''
            print(f"  {hits:>6,}  {ip:<16}  [{classes}]{protected}")

    # Protected IPs summary
    protected = set()
    for cls in ('PAYMENT', 'MONITORING'):
        protected.update(data['ua_class_ips'].get(cls, set()))
    if protected:
        header("IPs protegees (paiement + monitoring)")
        print(f"  {C.CYAN}Ces IPs ne seront jamais proposees au ban dans 'actions'{C.RESET}\n")
        for ip in sorted(protected):
            classes = ','.join(sorted(data['ip_classes'].get(ip, set())))
            hits = data['ip_counts'].get(ip, 0)
            print(f"  {hits:>8,}  {ip:<16}  [{classes}]")


def _day_sort_key(k):
    try:
        return datetime.strptime(k, '%d/%b/%Y')
    except ValueError:
        return datetime.min


def _month_sort_key(k):
    try:
        return datetime.strptime(k, '%b/%Y')
    except ValueError:
        return datetime.min


def _aggregate_months(day_stats):
    """Aggregate day-level stats into month-level."""
    month_stats = defaultdict(lambda: {'total': 0, 'ips': set(), 'threats': 0,
                                        'bytes': 0, 's4xx': 0, 's5xx': 0, 'bots': 0})
    for pkey, ds in day_stats.items():
        mkey = pkey[3:]  # '10/Mar/2026' -> 'Mar/2026'
        ms = month_stats[mkey]
        ms['total'] += ds['total']
        ms['ips'].update(ds['ips'])
        ms['threats'] += ds['threats']
        ms['bytes'] += ds['bytes']
        ms['s4xx'] += ds['s4xx']
        ms['s5xx'] += ds['s5xx']
        ms['bots'] += ds['bots']
    return dict(month_stats)


def cmd_timeline(data, cfg, **_):
    day_stats = data.get('day_stats', {})
    group_by = data.get('group_by')
    if not day_stats:
        print(f"  {C.YELLOW}Pas de donnees temporelles{C.RESET}")
        return
    if not group_by:
        print(f"  {C.YELLOW}Utiliser --group-by day|month{C.RESET}")
        return

    if group_by == 'month':
        stats = _aggregate_months(day_stats)
        sorted_keys = sorted(stats.keys(), key=_month_sort_key)
        label = 'mois'
    else:
        stats = day_stats
        sorted_keys = sorted(stats.keys(), key=_day_sort_key)
        label = 'jour'

    count_label = f"{len(sorted_keys)} {label}" if group_by == 'month' else f"{len(sorted_keys)} {label}(s)"
    header(f"Trafic par {label} ({count_label})")

    max_total = max(ds['total'] for ds in stats.values())

    print(f"  {'Periode':>12s}  {'Requetes':>10s}  {'IPs':>6s}  {'Menaces':>8s}  "
          f"{'4xx':>6s}  {'5xx':>5s}  {'Volume':>8s}  {'Bots':>6s}")
    print(f"  {'-'*12}  {'-'*10}  {'-'*6}  {'-'*8}  {'-'*6}  {'-'*5}  {'-'*8}  {'-'*6}")

    for pkey in sorted_keys:
        ds = stats[pkey]
        bar = fmt_bar(ds['total'], max_total, 12)
        threat_str = f"{C.RED}{ds['threats']:>8,}{C.RESET}" if ds['threats'] else f"{ds['threats']:>8,}"
        s5_str = f"{C.RED}{ds['s5xx']:>5,}{C.RESET}" if ds['s5xx'] else f"{ds['s5xx']:>5,}"
        print(f"  {pkey:>12s}  {ds['total']:>10,}  {len(ds['ips']):>6,}  {threat_str}  "
              f"{ds['s4xx']:>6,}  {s5_str}  {fmt_size(ds['bytes']):>8s}  {ds['bots']:>6,}  {bar}")


def _is_section_empty(fn, data, cfg):
    """Check if a security section would produce empty output."""
    checks = {
        cmd_scanners: lambda: not data['scanner_uas'],
        cmd_sql: lambda: not data['threat_ips'].get('SQL'),
        cmd_xss: lambda: not data['threat_ips'].get('XSS'),
        cmd_traversal: lambda: not data['threat_ips'].get('TRAVERSAL'),
        cmd_wp_attack: lambda: not data['threat_ips'].get('WP'),
        cmd_post_flood: lambda: not any(c > cfg.get('post_flood_threshold', 200)
                                       for ip, c in data['post_ips'].items()
                                       if not is_protected_ip(ip, data)),
    }
    return checks.get(fn, lambda: False)()


