            label = mkey
        month_json.append({'key': mkey, 'label': label, 'total': ms['total'],
                           'ips': len(ms['ips']), 'threats': ms['threats'],
                           's4xx': ms['s4xx'], 's5xx': ms['s5xx'],
                           'bytes': ms['bytes'], 'bots': ms['bots']})

    all_json = [{'key': 'all', 'label': 'Total', 'total': total, 'ips': unique_ips,
                 'threats': threats_total, 's4xx': s4xx, 's5xx': s5xx,
                 'bytes': total_bytes, 'bots': bots}]

    tl_json = json.dumps({'day': day_json, 'month': month_json, 'all': all_json}, separators=(',', ':'))

    # Protected IPs
    protected_ips = set()
    for cls in ('PAYMENT', 'MONITORING'):
        protected_ips.update(data['ua_class_ips'].get(cls, set()))

    # ── Build HTML ──
    parts = []
    parts.append(f'''<!DOCTYPE html><html lang="fr"><head><meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Rapport an4log — {date_from} &rarr; {date_to}</title>
<style>{HTML_CSS}</style></head><body>''')

    # ── Header ──
    parts.append(f'''<div class="hdr">
<h1>an4log <span>v{VERSION}</span></h1>
<div class="period">{date_from} &rarr; {date_to} &nbsp;&middot;&nbsp; {days_str}</div>
<div class="meta">{len(files)} fichier{'s' if len(files)>1 else ''} &middot; Parse en {elapsed:.2f}s &middot; Genere le {now:%d/%m/%Y a %H:%M}</div>
</div>''')

    # ── Nav ──
    nav_items = [('overview', 'Vue d\'ensemble'), ('traffic', 'Trafic')]
    nav_items.append(('security', 'Securite'))
    nav_items.append(('details', 'Details'))
    parts.append('<nav>' + ''.join(
        f'<a href="#{k}">{v}</a>' for k, v in nav_items) + '</nav>')

    parts.append('<main>')

    # ════════════════════════════════════════════════════════
    # SECTION 1: Vue d'ensemble
    # ════════════════════════════════════════════════════════
    parts.append('<section id="overview">')

    # KPI cards
    bot_pct = bots * 100 // total if total else 0
    parts.append('<div class="cards">')
    cards = [
        (f'{total:,}', 'Requetes', ''),
        (f'{unique_ips:,}', 'IPs uniques', ''),
        (fmt_size(total_bytes), 'Volume', ''),
        (f'{bots:,}', f'Bots ({bot_pct}%)', ''),
        (f'{s4xx:,}', 'Erreurs 4xx', 'alert' if s4xx > total * 0.2 else ''),
        (f'{s5xx:,}', 'Erreurs 5xx', 'alert' if s5xx > 0 else 'ok'),
    ]
    if threats_total:
        cards.append((f'{threats_total:,}', 'Menaces', 'alert'))
    if suspect_count:
        cards.append((f'{suspect_count}', 'IPs suspectes', 'alert'))
    for val, label, extra in cards:
        cls = f' {extra}' if extra else ''
        parts.append(f'<div class="card{cls}"><div class="v">{val}</div><div class="l">{label}</div></div>')
    parts.append('</div>')

    # Timeline
    if day_stats:
        default_mode = 'day' if n_days <= 90 else 'month'
        parts.append(f'''<h2>Evolution
<div class="btn-group">
<button class="tl-btn{' on' if default_mode=='day' else ''}" data-m="day" onclick="setTL('day')">Jour</button>
<button class="tl-btn{' on' if default_mode=='month' else ''}" data-m="month" onclick="setTL('month')">Mois</button>
<button class="tl-btn" data-m="all" onclick="setTL('all')">Tout</button>
</div></h2>
<div class="tl-wrap">
<div class="tl-chart" id="tl-chart"></div>
<div class="tl-kpis" id="tl-kpis"></div>
</div>''')

    # Classification
    class_colors = {
        'HUMAN': '#c9d1d9', 'PAYMENT': '#58a6ff', 'MONITORING': '#79c0ff',
        'LEGIT_BOT': '#3fb950', 'SEO': '#d29922', 'AI_BOT': '#e3b341', 'UNKNOWN': '#484f58',
    }
    class_labels = {
        'HUMAN': 'Humain', 'PAYMENT': 'Paiement', 'MONITORING': 'Monitoring',
        'LEGIT_BOT': 'Bots legitimes', 'SEO': 'SEO', 'AI_BOT': 'IA', 'UNKNOWN': 'Inconnu',
    }
    parts.append('<h2>Classification du trafic</h2>')
    parts.append('<div class="cl-bar">')
    for key in ('HUMAN', 'PAYMENT', 'MONITORING', 'LEGIT_BOT', 'SEO', 'AI_BOT', 'UNKNOWN'):
        count = data['ua_class_counts'].get(key, 0)
        if count > 0 and total > 0:
            pct = count / total * 100
            color = class_colors[key]
            parts.append(f'<div style="width:{max(pct, 0.5):.1f}%;background:{color}" '
                         f'title="{class_labels[key]}: {count:,} ({pct:.1f}%)"></div>')
    parts.append('</div><div class="legend">')
    for key in ('HUMAN', 'PAYMENT', 'MONITORING', 'LEGIT_BOT', 'SEO', 'AI_BOT', 'UNKNOWN'):
        count = data['ua_class_counts'].get(key, 0)
        if count > 0:
            color = class_colors[key]
            ips = len(data['ua_class_ips'].get(key, set()))
            pct = count / total * 100 if total else 0
            ip_str = f' &mdash; {ips} IPs' if ips else ''
            parts.append(f'<span><span class="dot" style="background:{color}"></span>'
                         f'{class_labels[key]}: {count:,} ({pct:.1f}%){ip_str}</span>')
    parts.append('</div>')
    parts.append('</section>')

    # ════════════════════════════════════════════════════════
    # SECTION 2: Trafic
    # ════════════════════════════════════════════════════════
    parts.append('<section id="traffic">')

    # Hours chart
    parts.append('<h2>Trafic par heure</h2>')
    hours = data['hour_counts']
    max_h = max(hours.values()) if hours else 1
    parts.append('<div class="h-chart">')
    for h in range(24):
        hk = f'{h:02d}'
        count = hours.get(hk, 0)
        height = int(count / max_h * 100) if max_h else 0
        cnt_label = f'{count:,}' if count > 0 else ''
        parts.append(f'<div class="h-bar">'
                     f'<div class="cnt">{cnt_label}</div>'
                     f'<div class="fill" style="height:{max(height, 2)}px" '
                     f'title="{hk}h: {count:,} req"></div>'
                     f'<div class="lbl">{hk}h</div></div>')
    parts.append('</div>')

    # Top IPs
    parts.append(f'<h2>Top {n} IPs</h2>')
    items = data['ip_counts'].most_common(n)
    max_v = items[0][1] if items else 0
    raw_vals = [c for _, c in items]
    rows = []
    for ip, c in items:
        tags = ''.join(f'<span class="tag tag-{t}">{t}</span>' for t in sorted(data['ip_classes'].get(ip, set())))
        if is_protected_ip(ip, data):
            tags += ' <span class="tag tag-protected">PROTEGE</span>'
        cc = _esc(geo.get(ip, ''))
        ip_cell = f'{cc} {_esc(ip)}' if cc else _esc(ip)
        rows.append((f'{c:,}', f'<span class="pct">{c/total*100:.1f}%</span>', ip_cell, tags))
    parts.append(_table(['Hits', '%', 'IP', 'Type'], rows, bar_values=raw_vals, bar_max=max_v))

    # Top countries (if GeoIP available)
    if geo_full:
        country_ips = Counter()
        country_hits = Counter()
        for ip, hits in data['ip_counts'].items():
            cc, name = geo_full.get(ip, ('??', 'Inconnu'))
            key = f'{cc}|{name}'
            country_ips[key] += 1
            country_hits[key] += hits

        parts.append(f'<h2>Top {n} pays</h2>')
        items = country_hits.most_common(n)
        max_v = items[0][1] if items else 0
        raw_vals = [hits for _, hits in items]
        rows = []
        for key, hits in items:
            iso, name = key.split('|', 1)
            ips_count = country_ips[key]
            pct = hits / total * 100 if total else 0
            rows.append((f'{hits:,}', f'<span class="pct">{pct:.1f}%</span>',
                         f'{ips_count:,}', f'{_esc(iso)}', _esc(name)))
        parts.append(_table(['Hits', '%', 'IPs', 'Code', 'Pays'], rows,
                            bar_values=raw_vals, bar_max=max_v))

    # HTTP codes + URIs side by side
    parts.append('<div class="grid2"><div>')
    parts.append('<h3>Codes HTTP</h3>')
    items = data['status_counts'].most_common(n)
    max_v = items[0][1] if items else 0
    raw_vals = [c for _, c in items]
    rows = [(f'{c:,}', f'<span class="pct">{c/total*100:.1f}%</span>', str(s)) for s, c in items]
    parts.append(_table(['Hits', '%', 'Code'], rows, bar_values=raw_vals, bar_max=max_v))
    parts.append('</div><div>')
    parts.append('<h3>Top URIs</h3>')
    items = data['uri_counts'].most_common(n)
    max_v = items[0][1] if items else 0
    raw_vals = [c for _, c in items]
    rows = [(f'{c:,}', f'<span class="pct">{c/total*100:.1f}%</span>',
             f'<span title="{_esc(u)}">{_esc(u)}</span>') for u, c in items]
    parts.append(_table(['Hits', '%', 'URI'], rows, bar_values=raw_vals, bar_max=max_v))
    parts.append('</div></div>')
    parts.append('</section>')

    # ════════════════════════════════════════════════════════
    # SECTION 3: Securite
    # ════════════════════════════════════════════════════════
    parts.append('<section id="security">')
    parts.append('<h2>Securite</h2>')

    if threats_total or data['ip_threats']:
        # Threat summary
        labels = {'SQL': 'SQL Injection', 'XSS': 'XSS', 'TRAVERSAL': 'Path Traversal',
                  'SCAN': 'Scanners', 'WP': 'WordPress', 'SENSITIVE': 'Fichiers sensibles'}
        parts.append('<div class="status red"><div>')
        parts.append(f'<div class="title">{threats_total:,} menace{"s" if threats_total > 1 else ""} detectee{"s" if threats_total > 1 else ""}</div>')
        for ttype, label in labels.items():
            tcount = data['threat_counts'].get(ttype, 0)
            if tcount > 0:
                top_src = data['threat_ips'].get(ttype, Counter()).most_common(3)
                top_str = ' &mdash; ' + ', '.join(ip for ip, _ in top_src) if top_src else ''
                parts.append(f'<span class="tag tag-{ttype}">{ttype}</span> '
                             f'{_esc(label)}: <b>{tcount:,}</b>{top_str}<br>')
        parts.append('</div></div>')

        # IPs to ban
        attack_ips = sorted(data['ip_threats'].keys(),
                            key=lambda ip: ip_score(ip, data, cfg), reverse=True)
        attack_ips = [ip for ip in attack_ips
                      if not is_whitelisted(ip, wl_nets) and not is_protected_ip(ip, data)]
        if attack_ips:
            parts.append(f'<h3 style="color:#f85149;margin-top:16px">IPs a bannir ({len(attack_ips)})</h3>')
            rows = []
            raw_scores = []
            for ip in attack_ips[:n * 2]:
                hits = data['ip_counts'].get(ip, 0)
                score = ip_score(ip, data, cfg)
                raw_scores.append(score)
                tags = ''.join(f'<span class="tag tag-{t}">{t}</span>' for t in sorted(data['ip_threats'].get(ip, set())))
                cc = _esc(geo.get(ip, ''))
                rows.append((f'{score}', f'{hits:,}', cc, _esc(ip), tags,
                             f'<code style="font-size:.8em;color:#8b949e">iptables -A INPUT -s {_esc(ip)} -j DROP</code>'))
            parts.append(_table(['Score', 'Hits', 'Pays', 'IP', 'Types', 'Commande'], rows,
                                bar_values=raw_scores, bar_max=max(raw_scores) if raw_scores else 0, bar_class='red'))
    else:
        parts.append('<div class="status green"><div class="icon">&#10003;</div>'
                     '<div class="text">Aucune menace detectee</div></div>')

    # Protected IPs
    if protected_ips:
        parts.append('<h3 style="margin-top:16px">IPs protegees</h3>')
        prot_lines = []
        for ip in sorted(protected_ips, key=lambda x: data['ip_counts'].get(x, 0), reverse=True):
            hits = data['ip_counts'].get(ip, 0)
            tags_list = sorted(data['ip_classes'].get(ip, set()))
            tags_html = ' '.join(f'<span class="tag tag-{t}">{t}</span>' for t in tags_list)
            prot_lines.append(f'{_esc(ip)} &mdash; {hits:,} hits &mdash; {tags_html}')
        parts.append('<div class="callout green"><b>Ces IPs ne sont jamais proposees au ban :</b><br>'
                     + '<br>'.join(prot_lines) + '</div>')

    parts.append('</section>')

    # ════════════════════════════════════════════════════════
    # SECTION 4: Details
    # ════════════════════════════════════════════════════════
    parts.append('<section id="details">')
    parts.append('<div class="grid2"><div>')

    # Bots
    parts.append('<h3>Bots / Crawlers</h3>')
    if data['bot_uas']:
        items = data['bot_uas'].most_common(n)
        max_v = items[0][1] if items else 0
        raw_vals = [c for _, c in items]
        rows = [(f'{c:,}', f'<span title="{_esc(ua)}">{_esc(ua[:80])}</span>') for ua, c in items]
        parts.append(_table(['Hits', 'User-Agent'], rows, bar_values=raw_vals, bar_max=max_v))
    else:
        parts.append('<div style="color:#8b949e;padding:12px">Aucun bot detecte</div>')

    parts.append('</div><div>')

    # 404s
    parts.append('<h3>Top erreurs 404</h3>')
    items = data['uri_404'].most_common(n)
    if items:
        max_v = items[0][1] if items else 0
        raw_vals = [c for _, c in items]
        rows = [(f'{c:,}', f'<span title="{_esc(u)}">{_esc(u)}</span>') for u, c in items]
        parts.append(_table(['Hits', 'URI'], rows, bar_values=raw_vals, bar_max=max_v, bar_class='yellow'))
    else:
        parts.append('<div style="color:#8b949e;padding:12px">Aucune erreur 404</div>')

    parts.append('</div></div>')
    parts.append('</section>')

    parts.append('</main>')

    # ── Footer ──
    parts.append(f'<footer>an4log v{VERSION} &middot; Genere le {now:%d/%m/%Y a %H:%M}</footer>')

    # ── JavaScript ──
    parts.append(f'<script>var TL={tl_json};var tlMode="{default_mode if day_stats else "day"}";')
    parts.append(HTML_JS)
    parts.append('</script>')

    parts.append('</body></html>')

    return '\n'.join(parts)

# ── Main ─────────────────────────────────────────────────────────────

COMMANDS = {
    'all': cmd_all, 'summary': cmd_summary, 'ip-profile': cmd_ip_profile,
    'ip': cmd_ip, 'ua': cmd_ua, 'uri': cmd_uri, 'prefix': cmd_prefix,
    'status': cmd_status, 'heavy': cmd_heavy, 'methods': cmd_methods,
    'hour': cmd_hour, 'minute': cmd_minute, 'slow': cmd_slow,
    '404': cmd_404, '403': cmd_403, 'crawlers': cmd_crawlers,
    'suspect': cmd_suspect, 'empty-ua': cmd_empty_ua, 'burst': cmd_burst,
    'threat': cmd_threat, 'actions': cmd_actions,
    'sql': cmd_sql, 'xss': cmd_xss, 'traversal': cmd_traversal,
    'scanners': cmd_scanners, 'wp-attack': cmd_wp_attack, 'post-flood': cmd_post_flood,
    'countries': cmd_countries, 'classify': cmd_classify, 'timeline': cmd_timeline,
}


def main():
    C.init()

    parser = argparse.ArgumentParser(
        prog='an4log', description=f'an4log v{VERSION} - Analyseur de logs Apache/Nginx',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""Commandes:
  Analyse generale:
    all             Toutes les analyses (defaut)
    summary         Dashboard rapide (stats + alertes)
    classify        Repartition du trafic par categorie (humain, paiement, bots...)

  Trafic:
    ip              Top IPs par nombre de requetes
    ua              Top User-Agents
    uri             Top URIs (sans query string)
    prefix          Top prefixes IP (xxx.xxx.*)
    status          Top codes HTTP
    heavy           Top IPs par volume transfere (octets)
    methods         Repartition des methodes HTTP
    timeline        Trafic par jour ou mois (necessite --group-by)
    hour            Repartition des requetes par heure
    minute          Pics de trafic par minute
    slow            Requetes les plus lentes
    404             Top URIs en erreur 404
    403             Top IPs bloquees (403)
    crawlers        Bots/crawlers detectes
    suspect         IPs suspectes (> seuil de requetes)
    empty-ua        Requetes sans User-Agent
    burst           Detection de burst par IP/minute
    post-flood      Flood de requetes POST par IP

  Securite:
    threat          Vue combinee de toutes les menaces
    actions         Suggestions iptables / fail2ban / ipset
    sql             Tentatives d'injection SQL
    xss             Tentatives XSS
    traversal       Tentatives de path traversal
    scanners        Detection de scanners (nikto, sqlmap...)
    wp-attack       Attaques WordPress

  GeoIP:
    countries       Top pays par nombre de hits
    setup-geoip     Telecharger la base GeoLite2

Exemples:
  an4log -d /var/log/apache2/access.log          # analyse complete
  an4log -d access.log -n 20 status              # top 20 codes HTTP
  an4log -d access.log --since 1h threat         # menaces derniere heure
  an4log -d access.log --ip 1.2.3.4              # profil d'une IP
  an4log -d 'access*.log' -d 'access*.log.gz'    # multi-fichiers + gz
  an4log -d access.log actions                   # suggestions blocage
  an4log -d access.log actions --output-ips      # IPs brutes (pour pipe)
  an4log -d access.log summary                   # dashboard rapide
  an4log -d access*.log --group-by day            # stats par jour
  an4log -d access*.log --group-by month          # stats par mois
  an4log -d access.log --html rapport.html        # rapport HTML complet""")

    parser.add_argument('-d', action='append', dest='files', default=[], metavar='FILE',
                        help='Fichier(s) log (glob ok, repeatable)')
    parser.add_argument('-n', type=int, dest='top_n', help='Nombre de resultats (defaut: 10)')
    parser.add_argument('-g', dest='geoip_db', help='Chemin base GeoLite2-Country.mmdb')
    parser.add_argument('-w', dest='whitelist_file', help='Fichier whitelist externe')
    parser.add_argument('-c', dest='config_file', help='Fichier de configuration')
    parser.add_argument('--since', help='Filtrer depuis: 30m, 2h, 1d, 2026-03-09')
    parser.add_argument('--ip', dest='filter_ip', help='Filtrer / profiler une IP')
    parser.add_argument('--exclude-bots', action='store_true', help='Exclure les bots connus')
    parser.add_argument('--output-ips', action='store_true', help='Sortie IPs brutes (pour pipe)')
    parser.add_argument('--group-by', choices=['day', 'month'], help='Grouper par jour ou mois')
    parser.add_argument('--html', metavar='FILE', help='Generer un rapport HTML')
    parser.add_argument('--suspect-threshold', type=int, help='Seuil IPs suspectes (defaut: 500)')
    parser.add_argument('--ua-threshold', type=int, help='Seuil IPs sans UA (defaut: 50)')
    parser.add_argument('--burst-threshold', type=int, help='Seuil burst req/min (defaut: 30)')
    parser.add_argument('-v', '--version', action='version', version=f'an4log v{VERSION}')
    parser.add_argument('remaining', nargs='*', help=argparse.SUPPRESS)

    args = parser.parse_args()

    # Split remaining args into command and extra files
    # Known commands go to args.command, everything else is a log file
    args.command = 'all'
    if args.remaining:
        for i, arg in enumerate(args.remaining):
            if arg in COMMANDS or arg == 'setup-geoip':
                args.command = arg
                extra_files = args.remaining[:i] + args.remaining[i+1:]
                break
        else:
            extra_files = args.remaining
        if args.files is None:
            args.files = []
        args.files.extend(extra_files)

    # Config
    cfg = load_config(args.config_file)
    if args.top_n:
        cfg['top_n'] = args.top_n
    if args.geoip_db:
        cfg['geoip_db'] = args.geoip_db
    if args.suspect_threshold:
        cfg['suspect_threshold'] = args.suspect_threshold
    if args.ua_threshold:
        cfg['ua_threshold'] = args.ua_threshold
    if args.burst_threshold:
        cfg['burst_threshold'] = args.burst_threshold
    if args.output_ips:
        C.BOLD = C.RED = C.GREEN = C.YELLOW = C.CYAN = C.RESET = ''

    # GeoIP auto-detect
    if not cfg.get('geoip_db'):
        cfg['geoip_db'] = find_geoip_db()

    # setup-geoip: no log needed
    if args.command == 'setup-geoip':
        cmd_setup_geoip(cfg)
        sys.exit(0)

    # Validate -d
    if not args.files:
        parser.error("fichier log requis (-d <fichier>)")

    # Resolve files
    files = resolve_files(args.files)
    if not files:
        print(f"{C.RED}Erreur: aucun fichier log trouve{C.RESET}", file=sys.stderr)
        sys.exit(2)

    # Validate format
    if not validate_format(files):
        sys.exit(2)

    # Header
    if not args.output_ips:
        print(f"{C.BOLD}an4log v{VERSION}{C.RESET}")
        if len(files) == 1:
            print(f"Fichier: {C.CYAN}{files[0]}{C.RESET}")
        else:
            print(f"Fichiers: {C.BOLD}{len(files)}{C.RESET} fichiers")
            for f in files[:5]:
                print(f"  {C.CYAN}{f}{C.RESET}")
            if len(files) > 5:
                print(f"  ... +{len(files) - 5} autres")

    # IP profile shortcut
    command = args.command
    if args.filter_ip and command == 'all':
        command = 'ip-profile'

    # Parse (single pass)
    t0 = time.monotonic()
    data = parse_log(files, cfg, since=args.since, filter_ip=args.filter_ip,
                     exclude_bots=args.exclude_bots, group_by=args.group_by)
    elapsed = time.monotonic() - t0

    if not args.output_ips:
        total = data['total']
        size_bytes = sum(os.path.getsize(f) for f in files)
        print(f"Lignes: {C.BOLD}{total:,}{C.RESET} | Taille: {C.BOLD}{fmt_size(size_bytes)}{C.RESET} | Parse: {C.BOLD}{elapsed:.2f}s{C.RESET}")
        if data['parse_errors'] > 0:
            warn(f"{data['parse_errors']} ligne(s) non parsee(s)")
        if args.since:
            print(f"Filtre: {C.YELLOW}--since {args.since}{C.RESET}")
        if args.filter_ip:
            print(f"Filtre IP: {C.YELLOW}{args.filter_ip}{C.RESET}")
        if args.exclude_bots:
            print(f"Filtre: {C.YELLOW}--exclude-bots{C.RESET}")

    # Whitelist
    wl_raw, wl_nets = load_whitelist(cfg, args.whitelist_file)

    # GeoIP for actions/html
    geo = {}
    geo_full = {}
    if command in ('actions', 'threat') or args.html:
        if args.html:
            # Resolve ALL IPs for HTML report (country ranking)
            all_ips = set(data['ip_counts'].keys())
            geo_full = resolve_geoip_full(all_ips, cfg.get('geoip_db', ''))
            geo = {ip: cc for ip, (cc, _) in geo_full.items()}
        else:
            all_ips = set(data['ip_threats'].keys())
            all_ips.update(ip for ip, c in data['ip_counts'].items() if c > cfg['suspect_threshold'])
            all_ips.update(ip for ip, c in data['empty_ua_ips'].items() if c > cfg['ua_threshold'])
            geo = resolve_geoip(all_ips, cfg.get('geoip_db', ''))

    # HTML report
    if args.html:
        html_content = generate_html_report(data, cfg, files, elapsed, geo, wl_raw, wl_nets, geo_full)
        with open(args.html, 'w') as f:
            f.write(html_content)
        print(f"{C.GREEN}Rapport HTML genere: {args.html}{C.RESET}")
        if not args.output_ips and command == 'all':
            sys.exit(1 if data['threat_counts'] else 0)

    # Dispatch
    if command not in COMMANDS:
        print(f"{C.RED}Commande inconnue: {command}{C.RESET}", file=sys.stderr)
        parser.print_help()
        sys.exit(2)

    COMMANDS[command](data=data, cfg=cfg, geo=geo, wl_raw=wl_raw, wl_nets=wl_nets,
                      filter_ip=args.filter_ip or '', output_ips=args.output_ips)

    # Return code: 1 if threats detected
    has_threats = bool(data['threat_counts'])
    sys.exit(1 if has_threats else 0)


if __name__ == '__main__':
    main()
