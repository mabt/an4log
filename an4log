    cmd_scanners: 'Scanners', cmd_sql: 'SQL', cmd_xss: 'XSS',
    cmd_traversal: 'Traversal', cmd_wp_attack: 'WordPress', cmd_post_flood: 'POST flood',
}


def cmd_all(data, cfg, **kw):
    cmds = [cmd_summary, cmd_classify]
    if data.get('group_by'):
        cmds.append(cmd_timeline)
    cmds += [cmd_ip, cmd_ua, cmd_uri, cmd_prefix,
             cmd_status, cmd_hour, cmd_countries, cmd_404, cmd_crawlers, cmd_suspect,
             cmd_empty_ua]

    # Security sections: show empty ones as a compact line
    sec_cmds = [cmd_scanners, cmd_sql, cmd_xss, cmd_traversal, cmd_wp_attack, cmd_post_flood]
    empty_labels = []
    for fn in sec_cmds:
        if _is_section_empty(fn, data, cfg):
            empty_labels.append(_SECTION_LABELS[fn])
        else:
            cmds.append(fn)
    if empty_labels:
        cmds.append(lambda data, cfg, _empty=empty_labels, **kw:
                     print(f"\n  {C.GREEN}Aucune detection :{C.RESET} {', '.join(_empty)}"))

    for fn in cmds:
        fn(data, cfg, **kw)

