# ── Colors ───────────────────────────────────────────────────────────

class C:
    BOLD = RED = GREEN = YELLOW = CYAN = RESET = ''

    @classmethod
    def init(cls):
        if sys.stdout.isatty() and os.environ.get('NO_COLOR') is None:
            cls.BOLD, cls.RED, cls.GREEN = '\033[1m', '\033[0;31m', '\033[0;32m'
            cls.YELLOW, cls.CYAN, cls.RESET = '\033[0;33m', '\033[0;36m', '\033[0m'


def header(title):
    print(f"\n{C.BOLD}{C.GREEN}=== {title} ==={C.RESET}\n")


def warn(msg):
    print(f"{C.YELLOW}[!] {msg}{C.RESET}", file=sys.stderr)


def fmt_size(n):
    for unit in ('o', 'K', 'M', 'G', 'T'):
        if abs(n) < 1024:
            return f"{n:.1f}{unit}" if unit != 'o' else f"{n}{unit}"
        n /= 1024
    return f"{n:.1f}P"


def fmt_bar(val, max_val, width=20):
    if max_val <= 0:
        return ''
    filled = int(val / max_val * width)
    return f"{C.CYAN}{'█' * filled}{'░' * (width - filled)}{C.RESET}"


def fmt_pct(val, total):
    if total <= 0:
        return ''
    return f"{val / total * 100:5.1f}%"

# ── Config ───────────────────────────────────────────────────────────

def load_config(path=None):
    cfg = dict(DEFAULTS)
    paths = [path] if path else CONFIG_PATHS
    for p in paths:
        if p and os.path.isfile(p):
            with open(p) as f:
                for line in f:
                    line = line.split('#')[0].strip()
                    if '=' not in line:
                        continue
                    key, val = line.split('=', 1)
                    key, val = key.strip(), val.strip()
                    if key in ('top_n', 'suspect_threshold', 'ua_threshold',
                               'prefix_threshold', 'burst_threshold'):
                        cfg[key] = int(val)
                    elif key == 'whitelist':
                        cfg['whitelist'] = [x.strip() for x in val.split(',') if x.strip()]
                    elif key in ('geoip_db', 'f2b_whitelist_path'):
                        cfg[key] = val
            break
    return cfg

# ── Whitelist ────────────────────────────────────────────────────────

def load_whitelist(cfg, extra_file=None):
    raw = list(cfg.get('whitelist', []))
    # fail2ban
    f2b = cfg.get('f2b_whitelist_path', '')
    if f2b and os.path.isfile(f2b):
        with open(f2b) as f:
            for line in f:
                line = line.split('#')[0].strip()
                if not line or line.startswith('['):
                    continue
                if '=' in line:
                    line = line.split('=', 1)[1]
                for token in line.split():
                    if re.match(r'^[0-9]+\.', token):
                        raw.append(token)
    # external file (-w)
    if extra_file and os.path.isfile(extra_file):
        with open(extra_file) as f:
            for line in f:
                line = line.split('#')[0].strip()
                if line and re.match(r'^[0-9]+\.', line):
                    raw.append(line)
    # parse into networks
    nets = []
    for entry in raw:
        try:
            nets.append(ip_network(entry if '/' in entry else entry + '/32', strict=False))
        except ValueError:
            pass
    return raw, nets


def is_whitelisted(ip_str, nets):
    try:
        addr = ip_address(ip_str)
    except ValueError:
        return False
    return any(addr in net for net in nets)


def is_prefix_whitelisted(prefix, raw_wl):
    return any(e.startswith(prefix + '.') for e in raw_wl)

# ── Log Parsing (single pass) ───────────────────────────────────────

def open_log(filepath):
    if filepath.endswith('.gz'):
        return gzip.open(filepath, 'rt', errors='replace')
    return open(filepath, errors='replace')


def compute_cutoff(since_str):
    now = datetime.now()
    m = re.match(r'^(\d+)([mhd])$', since_str)
    if m:
        n, unit = int(m.group(1)), m.group(2)
        delta = {'m': timedelta(minutes=n), 'h': timedelta(hours=n), 'd': timedelta(days=n)}
        return now - delta[unit]
    if re.match(r'^\d{4}-\d{2}-\d{2}$', since_str):
        try:
            return datetime.strptime(since_str, '%Y-%m-%d')
        except ValueError:
            pass
    warn(f"Format --since non reconnu: {since_str} (utiliser: 30m, 2h, 1d, 2026-03-09)")
    return None


_MONTHS = {'Jan':1,'Feb':2,'Mar':3,'Apr':4,'May':5,'Jun':6,
           'Jul':7,'Aug':8,'Sep':9,'Oct':10,'Nov':11,'Dec':12}

def parse_timestamp(ts_str):
    """Fast manual parsing of '10/Mar/2026:08:18:55 +0100' (6x faster than strptime)."""
    try:
        return datetime(int(ts_str[7:11]), _MONTHS[ts_str[3:6]], int(ts_str[0:2]),
                        int(ts_str[12:14]), int(ts_str[15:17]), int(ts_str[18:20]))
    except (KeyError, ValueError, IndexError):
        return None


def validate_format(files):
    """Check first lines match combined log format."""
    checked, matched = 0, 0
    for filepath in files[:1]:
        try:
            with open_log(filepath) as f:
                for line in f:
                    if not line.strip():
                        continue
                    checked += 1
                    if LOG_RE.match(line):
                        matched += 1
                    if checked >= 10:
                        break
        except (IOError, OSError):
            pass
    if checked > 0 and matched < checked * 0.5:
        warn(f"Format de log non reconnu ({matched}/{checked} lignes parsees)")
        warn("Format attendu: Combined Log Format (Apache/Nginx)")
        return False
    return True


def parse_log(files, cfg, since=None, filter_ip=None, exclude_bots=False, group_by=None):
    """Single-pass parser — all stats in one iteration."""
    profiling = bool(filter_ip)  # detailed per-IP data only when profiling
    data = {
        'total': 0, 'parse_errors': 0,
        'ip_counts': Counter(), 'ua_counts': Counter(), 'uri_counts': Counter(),
        'status_counts': Counter(), 'ip_bytes': Counter(), 'prefix_counts': Counter(),
        'hour_counts': Counter(), 'minute_counts': Counter(), 'method_counts': Counter(),
        'uri_404': Counter(), 'ip_403': Counter(), 'post_ips': Counter(),
        'empty_ua_ips': Counter(), 'bot_uas': Counter(), 'bot_count': 0,
        'ip_threats': defaultdict(set), 'threat_counts': Counter(),
        'threat_ips': defaultdict(Counter), 'scanner_uas': Counter(),
        'ua_class_counts': Counter(), 'ua_class_ips': defaultdict(set),
        'ip_classes': defaultdict(set), 'payment_uri_hits': Counter(),
        'ip_statuses': defaultdict(Counter),
        'ip_uas': defaultdict(set) if profiling else None,
        'ip_uris': defaultdict(Counter) if profiling else None,
        'ip_methods': defaultdict(Counter) if profiling else None,
        'ip_hours': defaultdict(Counter) if profiling else None,
        'ip_burst': defaultdict(Counter),
        'ip_first_seen': {}, 'ip_last_seen': {},
        'slow_requests': [],
        'day_stats': defaultdict(lambda: {
            'total': 0, 'ips': set(), 'threats': 0, 'bytes': 0,
            's4xx': 0, 's5xx': 0, 'bots': 0,
        }),
        'group_by': group_by,
    }

    cutoff = compute_cutoff(since) if since else None

    # Unified UA cache: ua -> (is_bot, is_scanner, ua_class)
    _ua_cache = {}

    # Local refs for hot loop performance
    _log_re = LOG_RE
    _parse_ts = parse_timestamp
    _threat_pats = list(THREAT_PATTERNS.items())
    _payment_re = PAYMENT_URI_RE
    _bot_re = BOT_RE
    _scanner_re = SCANNER_RE
    _ua_classes = UA_CLASSES
    ip_counts = data['ip_counts']
    ua_counts = data['ua_counts']
    status_counts = data['status_counts']
    method_counts = data['method_counts']
    ip_bytes = data['ip_bytes']
    uri_counts = data['uri_counts']
    prefix_counts = data['prefix_counts']
    hour_counts = data['hour_counts']
    minute_counts = data['minute_counts']
    ip_burst = data['ip_burst']
    ip_statuses = data['ip_statuses']
    uri_404 = data['uri_404']
    ip_403 = data['ip_403']
    post_ips = data['post_ips']
    empty_ua_ips = data['empty_ua_ips']
    bot_uas = data['bot_uas']
    ip_threats = data['ip_threats']
    threat_counts = data['threat_counts']
    threat_ips = data['threat_ips']
    scanner_uas = data['scanner_uas']
    ua_class_counts = data['ua_class_counts']
    ua_class_ips = data['ua_class_ips']
    ip_classes = data['ip_classes']
    payment_uri_hits = data['payment_uri_hits']
    ip_first_seen = data['ip_first_seen']
    ip_last_seen = data['ip_last_seen']
    slow_requests = data['slow_requests']
    day_stats = data['day_stats']
    top_n = cfg['top_n']
    slow_limit = top_n * 2

    # Profile-only structures
    ip_uas = data['ip_uas']
    ip_uris = data['ip_uris']
    ip_methods = data['ip_methods']
    ip_hours = data['ip_hours']

    total = 0
    bot_count = 0
    parse_errors = 0
    show_progress = sys.stderr.isatty() and len(files) > 1

    for file_idx, filepath in enumerate(files):
        if show_progress:
            print(f"\r  [{file_idx+1}/{len(files)}] {os.path.basename(filepath):<40s}", end='', file=sys.stderr)
        try:
            with open_log(filepath) as f:
                for line in f:
                    m = _log_re.match(line)
                    if not m:
                        parse_errors += 1
                        continue

                    ip, ts_str, method, uri, s_status, s_size, _, ua = m.groups()
                    status = int(s_status)
                    size = int(s_size) if s_size != '-' else 0

                    # Filters
                    if filter_ip and ip != filter_ip:
                        continue
                    ts = _parse_ts(ts_str)
                    if cutoff and ts and ts < cutoff:
                        continue

                    # UA cache: (is_bot, is_scanner, ua_class)
                    ua_info = _ua_cache.get(ua)
                    if ua_info is None:
                        _is_bot = bool(_bot_re.search(ua))
                        _is_scanner = bool(_scanner_re.search(ua))
                        _cls = None
                        for cls_name, cls_re in _ua_classes:
                            if cls_re.search(ua):
                                _cls = cls_name
                                break
                        ua_info = (_is_bot, _is_scanner, _cls)
                        _ua_cache[ua] = ua_info
                    is_bot, is_scanner, ua_cls = ua_info

                    if exclude_bots and is_bot:
                        continue

                    total += 1

                    # Day stats (always collected at day level for HTML timeline)
                    if ts:
                        pkey = ts_str[:11]  # '10/Mar/2026'
                        ds = day_stats[pkey]
                        ds['total'] += 1
                        ds['ips'].add(ip)
                        ds['bytes'] += size
                        if 400 <= status < 500:
                            ds['s4xx'] += 1
                        elif 500 <= status < 600:
                            ds['s5xx'] += 1
                        if is_bot:
                            ds['bots'] += 1

                    # Basic counts
                    ip_counts[ip] += 1
                    ua_counts[ua] += 1
                    status_counts[status] += 1
                    method_counts[method] += 1
                    ip_bytes[ip] += size

                    # URI (strip query)
                    qpos = uri.find('?')
                    clean_uri = uri[:qpos] if qpos > 0 else uri
                    if len(clean_uri) > 1:
                        uri_counts[clean_uri] += 1

                    # Prefix
                    dot1 = ip.find('.')
                    if dot1 > 0:
                        dot2 = ip.find('.', dot1 + 1)
                        if dot2 > 0:
                            prefix_counts[ip[:dot2]] += 1

                    # Time
                    if ts:
                        h = ts_str[12:14]
                        mkey = ts_str[:17]
                        hour_counts[h] += 1
                        minute_counts[mkey] += 1
                        ip_burst[ip][mkey] += 1
                        if profiling:
                            ip_hours[ip][h] += 1
                        if ip not in ip_first_seen or ts < ip_first_seen[ip]:
                            ip_first_seen[ip] = ts
                        if ip not in ip_last_seen or ts > ip_last_seen[ip]:
                            ip_last_seen[ip] = ts

                    # Status
                    ip_statuses[ip][status] += 1
                    if status == 404:
                        uri_404[uri] += 1
                    if status == 403:
                        ip_403[ip] += 1
                    if method == 'POST':
                        post_ips[ip] += 1
                    if ua in ('-', ''):
                        empty_ua_ips[ip] += 1
                    if is_bot:
                        bot_count += 1
                        bot_uas[ua] += 1

                    # UA classification (from cache)
                    if ua_cls:
                        ua_class_counts[ua_cls] += 1
                        ua_class_ips[ua_cls].add(ip)
                        ip_classes[ip].add(ua_cls)
                    elif ua not in ('-', '') and not is_bot:
                        ua_class_counts['HUMAN'] += 1
                    elif not is_bot:
                        ua_class_counts['UNKNOWN'] += 1

                    # Payment URIs
                    if _payment_re.search(uri):
                        payment_uri_hits[ip] += 1

                    # IP profile (only when --ip is set)
                    if profiling:
                        ip_uas[ip].add(ua)
                        ip_uris[ip][uri] += 1
                        ip_methods[ip][method] += 1

                    # Threats — on URI only
                    _has_threat = False
                    for tname, pat in _threat_pats:
                        if pat.search(uri):
                            if tname == 'WP' and status == 200:
                                continue
                            ip_threats[ip].add(tname)
                            threat_counts[tname] += 1
                            threat_ips[tname][ip] += 1
                            _has_threat = True

                    # Scanners — from cache
                    if is_scanner:
                        ip_threats[ip].add('SCAN')
                        threat_counts['SCAN'] += 1
                        scanner_uas[ua] += 1
                        _has_threat = True

                    if _has_threat and ts:
                        ds['threats'] += 1

                    # Slow (response time = last field if numeric)
                    raw_parts = line.rstrip().rsplit(None, 1)
                    if len(raw_parts) == 2 and raw_parts[1].isdigit():
                        t = int(raw_parts[1])
                        if t > 0:
                            slow_requests.append((t, uri))
                            if len(slow_requests) > slow_limit:
                                slow_requests.sort(reverse=True)
                                del slow_requests[top_n:]

        except (IOError, OSError) as e:
            warn(f"Erreur lecture {filepath}: {e}")

    if show_progress:
        print(f"\r{' ' * 60}\r", end='', file=sys.stderr)

    data['total'] = total
    data['bot_count'] = bot_count
    data['parse_errors'] = parse_errors

    # Ensure profile structures exist for ip-profile even if empty
    if not profiling:
        data['ip_uas'] = defaultdict(set)
        data['ip_uris'] = defaultdict(Counter)
        data['ip_methods'] = defaultdict(Counter)
        data['ip_hours'] = defaultdict(Counter)

    slow_requests.sort(reverse=True)
    return data

# ── Scoring ──────────────────────────────────────────────────────────

def ip_score(ip, data, cfg):
    score = 0
    for t in data['ip_threats'].get(ip, set()):
        score += THREAT_SCORES.get(t, 1) * data['threat_ips'].get(t, {}).get(ip, 1)
    count = data['ip_counts'].get(ip, 0)
    if count > cfg['suspect_threshold']:
        score += (count - cfg['suspect_threshold']) // 100 * 3
    eu = data['empty_ua_ips'].get(ip, 0)
    if eu > cfg['ua_threshold']:
        score += eu
    return score

# ── GeoIP ────────────────────────────────────────────────────────────

def find_geoip_db(cfg_path=''):
    if cfg_path and os.path.isfile(cfg_path):
        return cfg_path
    for p in GEOIP_SEARCH_PATHS:
        if os.path.isfile(p):
            return p
    return ''


def resolve_geoip(ips, db_path):
    if not db_path or not os.path.isfile(db_path):
        return {}
    try:
        import geoip2.database
        reader = geoip2.database.Reader(db_path)
        result = {}
        for ip in ips:
            try:
                r = reader.country(ip)
                result[ip] = r.country.iso_code or '??'
            except Exception:
                result[ip] = '??'
        reader.close()
        return result
    except ImportError:
        return {}


def resolve_geoip_full(ips, db_path):
    """Returns dict ip -> (iso_code, country_name)."""
    if not db_path or not os.path.isfile(db_path):
        return {}
    try:
        import geoip2.database
        reader = geoip2.database.Reader(db_path)
        result = {}
        for ip in ips:
            try:
                r = reader.country(ip)
                result[ip] = (r.country.iso_code or '??', r.country.name or 'Inconnu')
            except Exception:
                result[ip] = ('??', 'Inconnu')
        reader.close()
        return result
    except ImportError:
        return {}

# ── Resolve log files ────────────────────────────────────────────────

def resolve_files(patterns):
    import glob
    files = []
    skipped = []
    for pattern in patterns:
        expanded = sorted(glob.glob(pattern))
        if not expanded:
            warn(f"Aucun fichier pour: {pattern}")
            continue
        for f in expanded:
            # Auto-skip error logs (not combined log format)
            basename = os.path.basename(f)
            if '.error.' in basename or basename.startswith('error'):
                skipped.append(basename)
                continue
            if os.path.isfile(f) and os.access(f, os.R_OK):
                files.append(f)
            else:
                warn(f"Fichier non lisible: {f}")
    if skipped:
        warn(f"Ignore {len(skipped)} error log(s): {', '.join(skipped)}")
    return files

# ── Display Commands ─────────────────────────────────────────────────

def fmt_key(key, max_len=40):
    """Truncate long keys (IPv6, URIs) for alignment."""
    s = str(key)
    if len(s) > max_len:
        return s[:max_len - 1] + '\u2026'
    return s


def show_top(counter, n, total=0, truncate=0):
    items = counter.most_common(n)
    if not items:
        return
    max_val = items[0][1]
    for key, count in items:
        pct = f"  {fmt_pct(count, total)}" if total else ''
        bar = f"  {fmt_bar(count, max_val)}" if total else ''
        display = fmt_key(key, truncate) if truncate else key
        print(f"  {count:>10,}{pct}{bar}  {display}")


def cmd_ip(data, cfg, **_):
    header(f"Top {cfg['top_n']} IPs")
    show_top(data['ip_counts'], cfg['top_n'], data['total'], truncate=42)


def cmd_ua(data, cfg, **_):
    header(f"Top {cfg['top_n']} User-Agents")
    show_top(data['ua_counts'], cfg['top_n'], data['total'])


def cmd_uri(data, cfg, **_):
    header(f"Top {cfg['top_n']} URIs")
    show_top(data['uri_counts'], cfg['top_n'], data['total'])


def cmd_prefix(data, cfg, **_):
    header(f"Top {cfg['top_n']} prefixes IP (xxx.xxx.*)")
    show_top(data['prefix_counts'], cfg['top_n'], data['total'])


def cmd_status(data, cfg, **_):
    header(f"Top {cfg['top_n']} codes HTTP")
