def cmd_actions(data, cfg, geo=None, wl_raw=None, wl_nets=None, output_ips=False, **_):
    if geo is None:
        geo = {}
    if wl_raw is None:
        wl_raw, wl_nets = [], []

    # Categorize IPs
    attack_ips = sorted(data['ip_threats'].keys(),
                        key=lambda ip: ip_score(ip, data, cfg), reverse=True)
    suspect_ips = [ip for ip, c in data['ip_counts'].most_common()
                   if c > cfg['suspect_threshold'] and ip not in data['ip_threats']]
    empty_ua_list = [ip for ip, c in data['empty_ua_ips'].most_common()
                     if c > cfg['ua_threshold'] and ip not in data['ip_threats']]
