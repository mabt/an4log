def cmd_setup_geoip(cfg):
    import urllib.request
    default_path = '/usr/share/GeoIP/GeoLite2-Country.mmdb' if os.getuid() == 0 \
        else os.path.expanduser('~/geoip/GeoLite2-Country.mmdb')
    db_path = cfg.get('geoip_db') or default_path
    db_dir = os.path.dirname(db_path)
    url = "https://github.com/P3TERX/GeoLite.mmdb/raw/download/GeoLite2-Country.mmdb"

    header("Installation GeoLite2-Country.mmdb")

    if os.path.isfile(db_path):
        age = (datetime.now() - datetime.fromtimestamp(os.path.getmtime(db_path))).days
        if age < 30:
            print(f"  {C.GREEN}Base deja presente: {db_path}{C.RESET}")
            print(f"  Mise a jour il y a {age} jour(s)")
            print(f"\n  Pour forcer: rm {db_path} && an4log setup-geoip")
            return
        else:
            print(f"  {C.YELLOW}Base > 30 jours, mise a jour...{C.RESET}")

    print(f"  Destination: {db_path}")
    print(f"  Source: github.com/P3TERX/GeoLite.mmdb\n")

    os.makedirs(db_dir, exist_ok=True)

    print(f"  {C.CYAN}Telechargement en cours...{C.RESET}")
    try:
        urllib.request.urlretrieve(url, db_path + '.tmp')
        os.rename(db_path + '.tmp', db_path)
    except Exception as e:
        if os.path.exists(db_path + '.tmp'):
