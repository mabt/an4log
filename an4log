        seen = set()
        for ip in attack_ips + suspect_ips + empty_ua_list:
            if ip not in seen and not is_whitelisted(ip, wl_nets) and not is_protected_ip(ip, data):
                print(ip)
                seen.add(ip)
        return

    # Whitelist info
    if wl_raw:
        print(f"\n  {C.CYAN}Whitelist active:{C.RESET} {' '.join(wl_raw)}")

